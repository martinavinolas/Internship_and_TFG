excel_output_path = os.path.join(base_path, 'Analisis_Label20_ATM26.xlsx')

# Usamos ExcelWriter para guardar múltiples hojas
with pd.ExcelWriter(excel_output_path, engine='openpyxl') as writer:
    df_resultados.to_excel(writer, sheet_name='Detalle por Caso', index=False)
